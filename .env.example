# =============================================================================
# Smart Notes Generator AI - Root Environment Variables
# Used by docker-compose.yml. Copy to `.env` and fill in real values.
# =============================================================================

# OpenAI (required for all AI generation features)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o

# Backend security (generate a strong random value for production)
SECRET_KEY=change_me_to_a_random_64_char_secret

# deployment environment: "development" | "production"
ENVIRONMENT=development
