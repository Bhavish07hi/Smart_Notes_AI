# =============================================================================
# Smart Notes Generator AI - Frontend Environment Variables
# Copy to `.env` and fill in values before running locally.
# In Docker/production the nginx proxy handles /api routing automatically.
# =============================================================================

# Base URL for the backend API (used in local dev without Docker proxy)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional: proxy target override for vite dev server
VITE_API_PROXY_TARGET=http://localhost:8000
